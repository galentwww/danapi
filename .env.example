# DandanPlay API
MIDDLEWARE_IMAGE=ghcr.io/galentwww/danapi:latest
DANDANPLAY_BASE_URL=https://api.dandanplay.net
APP_ID=your_app_id
APP_SECRET=your_app_secret
# Optional: comma-separated app_id:app_secret pairs. When set, this takes precedence.
DANDANPLAY_KEYS=
# Optional: log selected credential index and masked AppID. Never logs AppSecret.
DANDANPLAY_CREDENTIAL_LOG=false
# Optional: log danmaku cache source and refresh rule decisions.
DANMAKU_DECISION_LOG=false

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# PostgreSQL
POSTGRES_DB=dandanplay_middleware
POSTGRES_USER=middleware
POSTGRES_PASSWORD=middleware_password
POSTGRES_BIND_ADDRESS=127.0.0.1
POSTGRES_PORT=15432
DATABASE_URL=postgres://middleware:middleware_password@postgres:5432/dandanplay_middleware?sslmode=disable
DATABASE_READONLY_USER=middleware_readonly
DATABASE_READONLY_PASSWORD=readonly_password_change_me

# Server
SERVER_PORT=8080
GIN_MODE=release

# Cache durations, in seconds
SEARCH_CACHE_DURATION=3600
DANMAKU_CACHE_DURATION=1800

# Danmaku snapshot refresh durations, in seconds
REDIS_SNAPSHOT_TTL=172800
DEFAULT_REFRESH_INTERVAL=86400
EMPTY_DANMAKU_REFRESH_INTERVAL=3600
REFRESH_FAILURE_RETRY_INTERVAL=1800
REFRESH_ACCESS_WINDOW=86400
HOT_ACCESS_THRESHOLD=10
HOT_CHANGED_REFRESH_INTERVAL=7200
HOT_UNCHANGED_REFRESH_INTERVAL=21600
NORMAL_CHANGED_REFRESH_INTERVAL=43200
STABLE_REFRESH_INTERVAL=259200
ARCHIVED_REFRESH_INTERVAL=604800
REFRESH_QUEUE_SIZE=100
REFRESH_WORKER_COUNT=2

# CORS
CORS_ALLOW_ORIGINS=*
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS,PATCH,HEAD
CORS_ALLOW_HEADERS=Origin,Content-Type,Accept,Authorization,X-Requested-With
CORS_EXPOSE_HEADERS=
CORS_ALLOW_CREDENTIALS=false
CORS_MAX_AGE=86400
